# Required
APP_PASSWORD=changeme
SECRET_KEY=change-this-to-a-long-random-string
OPENROUTER_API_KEY=sk-or-...
MCP_TOKEN=change-this-to-a-long-random-string

# Optional — GitHub PAT increases rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=

# Embedding model (must be available on OpenRouter with /embeddings endpoint)
# Default: openai/text-embedding-3-small (dimension: 1536)
# Example alternatives:
#   EMBEDDING_MODEL=openai/text-embedding-3-large  →  EMBEDDING_DIMENSION=3072
#   EMBEDDING_MODEL=openai/text-embedding-ada-002  →  EMBEDDING_DIMENSION=1536
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Qdrant (defaults work for docker-compose)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# Sync schedule — hour in UTC (default 02:00)
SYNC_CRON_HOUR=2

# Misc
LOG_LEVEL=INFO
